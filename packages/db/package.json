{
  "name": "@labhive/db",
  "version": "1.0.0",
  "description": "Lab Hive Prisma schema + generated client (Cloudflare D1)",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./client": "./generated/prisma/client.ts"
  },
