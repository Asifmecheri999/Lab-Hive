# Copy to `web/wrangler.toml` and fill in your own worker name + API URL.
# NEXT_PUBLIC_API_URL is inlined into the browser bundle at BUILD time (see DEPLOYMENT.md),
# so build with the URL that matches the environment you deploy.
name = "labsynch-web"
main = ".open-next/worker.js"
compatibility_date = "2025-01-01"
compatibility_flags = ["nodejs_compat"]

[assets]
directory = ".open-next/assets"
binding = "ASSETS"

# Direct Worker-to-Worker call to the API (no public loopback).
[[services]]
binding = "API"
service = "labsynch-api"

[vars]
NEXT_PUBLIC_API_URL = "https://<your-api>.workers.dev"
API_URL = "https://<your-api>.workers.dev"

# AUTH_SECRET (NextAuth session secret) is a SECRET — set it with:
#   wrangler secret put AUTH_SECRET
